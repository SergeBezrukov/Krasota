<Window x:Class="Krasota.Appointments"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
        xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
        mc:Ignorable="d"
        Title="Appointments" Height="450" Width="800">
    <Grid>
        <Grid.Background>
            <LinearGradientBrush EndPoint="0.5,1" StartPoint="0.5,0">
                <GradientStop Color="White"/>
                <GradientStop Color="Red" Offset="1"/>
                <GradientStop Color="White" Offset="0.33"/>
                <GradientStop Color="#FF0800FF" Offset="0.33"/>
                <GradientStop Color="#FF0700FF" Offset="0.67"/>
                <GradientStop Color="#FEFE0909" Offset="0.678"/>
            </LinearGradientBrush>
        </Grid.Background>
        <Label x:Name="l_tabA" Content="Оказание услуг" HorizontalAlignment="Center" Height="37" Margin="0,43,0,0" VerticalAlignment="Top" Width="148" FontSize="20" FontWeight="Bold"/>

        <DataGrid x:Name="appointmentCell"
                  ItemsSource="{Binding AppointmentsClass}" ColumnWidth="*"
                  HorizontalAlignment="Left" Height="136" Margin="38,199,0,0" VerticalAlignment="Top" 
                  Width="716" AutoGenerateColumns="False" >
            <DataGrid.Columns>
                <DataGridTextColumn Header="Код" Binding="{Binding AppCode}" />
                <DataGridTextColumn Header="Код мастера" Binding="{Binding MasterCode}" />
                <DataGridTextColumn Header="Код клиента" Binding="{Binding ClientCode}" />
                <DataGridTextColumn Header="Тип услуги" Binding="{Binding ServTypeCode}" />
                <DataGridTextColumn Header="Услуга" Binding="{Binding ServCode}" />
                <DataGridTextColumn Header="Начало" Binding="{Binding QueueFrom}" />
                <DataGridTextColumn Header="Конец" Binding="{Binding QueueTo}" />
                <DataGridTextColumn Header="Дата" Binding="{Binding AppDate}" />
            </DataGrid.Columns>
        </DataGrid>

        <Button x:Name="b_appointmentDelete" Content="Удалить" HorizontalAlignment="Left" Height="37" Margin="420,123,0,0" VerticalAlignment="Top" Width="136" FontSize="16" FontWeight="Bold" Background="#FFEDEBA1" Click="b_appointmentDelete_Click"/>
        <Button x:Name="b_appointmentChange" Content="Изменить" HorizontalAlignment="Left" Height="37" Margin="593,123,0,0" VerticalAlignment="Top" Width="136" FontSize="16" FontWeight="Bold" Background="#FFF1EFA8" Click="b_appointmentChange_Click"/>
        <Button x:Name="b_appointmentReturn" Content="Вернуться" HorizontalAlignment="Left" Height="37" Margin="636,360,0,0" VerticalAlignment="Top" Width="136" FontSize="16" FontWeight="Bold" Background="#FFEFEDA9" Click="b_appointmentReturn_Click"/>
        <Button x:Name="b_appointmentAdd" Content="Добавить" HorizontalAlignment="Left" Height="37" Margin="38,123,0,0" VerticalAlignment="Top" Width="136" FontSize="16" FontWeight="Bold" Background="#FFEFEDA9" Click="b_appointmentAdd_Click"/>
        <Button x:Name="b_appointmentShow" Content="Показать" HorizontalAlignment="Left" Height="37" Margin="219,123,0,0" VerticalAlignment="Top" Width="136" FontSize="16" FontWeight="Bold" Background="#FFEFEDA9" Click="b_appointmentShow_Click"/>
    </Grid>
</Window>