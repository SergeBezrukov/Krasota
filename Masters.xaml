<Window x:Class="Krasota.Masters"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
        xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
        mc:Ignorable="d"
        Title="Masters" Height="450" Width="800">
    <Grid Background="#FFB0F7F7">
        <Label x:Name="l_tabM" Content="Мастера" HorizontalAlignment="Center" Height="37" Margin="0,43,0,0" VerticalAlignment="Top" Width="108" FontSize="20" FontWeight="Bold"/>

        <DataGrid x:Name="masterCell"
                  ItemsSource="{Binding MastersClass}" ColumnWidth="*"
                  HorizontalAlignment="Left" Height="136" Margin="38,199,0,0" VerticalAlignment="Top" 
                  Width="616" AutoGenerateColumns="False" >
            <DataGrid.Columns>
                <DataGridTextColumn Header="Код" Binding="{Binding MasterCode}" />
                <DataGridTextColumn Header="Имя" Binding="{Binding MasterName}" />
                <DataGridTextColumn Header="Телефон" Binding="{Binding MasterTel, UpdateSourceTrigger=PropertyChanged, Mode=TwoWay}" />
                <DataGridTextColumn Header="Тип услуги" Binding="{Binding ServTypeCode}" />
                <DataGridTextColumn Header="Активность" Binding="{Binding MasterActivity}" />
            </DataGrid.Columns>
        </DataGrid>

        <Button x:Name="b_masterDelete" Content="Удалить" HorizontalAlignment="Left" Height="37" Margin="420,123,0,0" VerticalAlignment="Top" Width="136" FontSize="16" FontWeight="Bold" Background="#FFEDEBA1" Click="b_masterDelete_Click"/>
        <Button x:Name="b_masterChange" Content="Изменить" HorizontalAlignment="Left" Height="37" Margin="593,123,0,0" VerticalAlignment="Top" Width="136" FontSize="16" FontWeight="Bold" Background="#FFF1EFA8" Click="b_masterChange_Click"/>
        <Button x:Name="b_masterReturn" Content="Вернуться" HorizontalAlignment="Left" Height="37" Margin="636,360,0,0" VerticalAlignment="Top" Width="136" FontSize="16" FontWeight="Bold" Background="#FFEFEDA9" Click="b_masterReturn_Click"/>
        <Button x:Name="b_masterAdd" Content="Добавить" HorizontalAlignment="Left" Height="37" Margin="38,123,0,0" VerticalAlignment="Top" Width="136" FontSize="16" FontWeight="Bold" Background="#FFEFEDA9" Click="b_masterAdd_Click"/>
        <Button x:Name="b_masterShow" Content="Показать" HorizontalAlignment="Left" Height="37" Margin="219,123,0,0" VerticalAlignment="Top" Width="136" FontSize="16" FontWeight="Bold" Background="#FFEFEDA9" Click="b_masterShow_Click"/>
    </Grid>
</Window>