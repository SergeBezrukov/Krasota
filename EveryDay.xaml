<Window x:Class="Krasota.EveryDay"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
        xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
        mc:Ignorable="d"
        Title="Запись на услугу" Height="600" Width="900">
    <Grid>
        <Grid.Background>
            <LinearGradientBrush EndPoint="0.5,1" StartPoint="0.5,0">
                <GradientStop Color="White"/>
                <GradientStop Color="Red" Offset="1"/>
                <GradientStop Color="Red" Offset="0.67"/>
                <GradientStop Color="#FF0700FF" Offset="0.665"/>
                <GradientStop Color="#FF0700FF" Offset="0.335"/>
                <GradientStop Color="White" Offset="0.33"/>
            </LinearGradientBrush>
        </Grid.Background>

        <Label Content="Запись клиента на услугу" HorizontalAlignment="Center" Margin="0,20,0,0" 
               VerticalAlignment="Top" Width="300" FontSize="20" FontWeight="Bold" Height="37"/>

        <!-- Левая колонка - выбор данных -->
        <GroupBox Header="Выбор данных" HorizontalAlignment="Left" Margin="30,70,0,0" 
                  VerticalAlignment="Top" Width="400" FontWeight="Bold" Height="350">
            <Grid>
                <!-- Выбор клиента -->
                <Label Content="Клиент:" HorizontalAlignment="Left" Margin="20,30,0,0" 
                       VerticalAlignment="Top" Width="120" FontWeight="Bold" Height="25"/>
                <ComboBox x:Name="cmbClients" HorizontalAlignment="Left" Margin="150,30,0,0" 
                         VerticalAlignment="Top" Width="200" FontSize="14" DisplayMemberPath="ClientName" Height="30"/>

                <!-- Выбор мастера -->
                <Label Content="Мастер:" HorizontalAlignment="Left" Margin="20,80,0,0" 
                       VerticalAlignment="Top" Width="120" FontWeight="Bold" Height="25"/>
                <ComboBox x:Name="cmbMasters" HorizontalAlignment="Left" Margin="150,80,0,0" 
                         VerticalAlignment="Top" Width="200" FontSize="14" DisplayMemberPath="MasterName" Height="30"/>

                <!-- Выбор услуги -->
                <Label Content="Услуга:" HorizontalAlignment="Left" Margin="20,130,0,0" 
                       VerticalAlignment="Top" Width="120" FontWeight="Bold" Height="25"/>
                <ComboBox x:Name="cmbServices" HorizontalAlignment="Left" Margin="150,130,0,0" 
                         VerticalAlignment="Top" Width="200" FontSize="14" DisplayMemberPath="ServName"
                         SelectionChanged="cmbServices_SelectionChanged" Height="30"/>

                <!-- Информация об услуге -->
                <Label Content="Цена:" HorizontalAlignment="Left" Margin="20,180,0,0" 
                       VerticalAlignment="Top" Width="120" FontWeight="Bold" Height="25"/>
                <TextBlock x:Name="txtServicePrice" HorizontalAlignment="Left" Margin="150,180,0,0" 
                          VerticalAlignment="Top" Width="200" FontSize="14" Text="0 руб" Height="25"/>

                <Label Content="Длительность:" HorizontalAlignment="Left" Margin="20,210,0,0" 
                       VerticalAlignment="Top" Width="120" FontWeight="Bold" Height="25"/>
                <TextBlock x:Name="txtServiceDuration" HorizontalAlignment="Left" Margin="150,210,0,0" 
                          VerticalAlignment="Top" Width="200" FontSize="14" Text="0 мин" Height="25"/>
            </Grid>
        </GroupBox>

        <!-- Правая колонка - выбор времени -->
        <GroupBox Header="Выбор даты и времени" HorizontalAlignment="Left" Margin="450,70,0,0" 
                  VerticalAlignment="Top" Width="400" FontWeight="Bold" Height="350">
            <Grid>
                <!-- Календарь -->
                <Label Content="Дата записи:" HorizontalAlignment="Left" Margin="20,30,0,0" 
                       VerticalAlignment="Top" Width="120" FontWeight="Bold" Height="25"/>
                <DatePicker x:Name="dpRecordDate" HorizontalAlignment="Left" Margin="150,30,0,0" 
                           VerticalAlignment="Top" Width="200" FontSize="14" 
                           SelectedDateChanged="dpRecordDate_SelectedDateChanged" Height="30"/>

                <!-- Выбор времени -->
                <Label Content="Время начала:" HorizontalAlignment="Left" Margin="20,80,0,0" 
                       VerticalAlignment="Top" Width="120" FontWeight="Bold" Height="25"/>
                <ComboBox x:Name="cmbTime" HorizontalAlignment="Left" Margin="150,80,0,0" 
                         VerticalAlignment="Top" Width="200" FontSize="14" Height="30"
                         SelectionChanged="cmbTime_SelectionChanged"/>

                <!-- Время окончания -->
                <Label Content="Время окончания:" HorizontalAlignment="Left" Margin="20,120,0,0" 
                       VerticalAlignment="Top" Width="120" FontWeight="Bold" Height="25"/>
                <TextBlock x:Name="txtEndTime" HorizontalAlignment="Left" Margin="150,120,0,0" 
                          VerticalAlignment="Top" Width="200" FontSize="14" Text="--:--" Height="25"/>

                <!-- Доступное время мастера -->
                <Label Content="Занятое время мастера:" HorizontalAlignment="Left" Margin="20,160,0,0" 
                       VerticalAlignment="Top" Width="150" FontWeight="Bold" FontSize="11" Height="25"/>
                <ListBox x:Name="lstBusyTime" HorizontalAlignment="Left" Margin="20,190,0,0" 
                        VerticalAlignment="Top" Width="350" FontSize="12" Height="120">
                    <ListBox.ItemTemplate>
                        <DataTemplate>
                            <TextBlock Text="{Binding BusyTimeInfo}" Foreground="Red"/>
                        </DataTemplate>
                    </ListBox.ItemTemplate>
                </ListBox>
            </Grid>
        </GroupBox>

        <!-- Кнопки -->
        <Button x:Name="btnSave" Content="Сохранить запись" HorizontalAlignment="Left" Margin="180,450,0,0" 
                VerticalAlignment="Top" Width="180" FontSize="16" FontWeight="Bold" Background="#FFEFEDA9" 
                Click="btnSave_Click" Height="40"/>

        <Button x:Name="btnClear" Content="Очистить" HorizontalAlignment="Left" Margin="380,450,0,0" 
                VerticalAlignment="Top" Width="120" FontSize="16" FontWeight="Bold" Background="#FFEDEBA1" 
                Click="btnClear_Click" Height="40"/>

        <Button x:Name="btnReturn" Content="Вернуться" HorizontalAlignment="Left" Margin="520,450,0,0" 
                VerticalAlignment="Top" Width="120" FontSize="16" FontWeight="Bold" Background="#FFF1EFA8" 
                Click="btnReturn_Click" Height="40"/>

        <!-- Сообщение о результате -->
        <Border BorderBrush="Gray" BorderThickness="1" Background="White" HorizontalAlignment="Left" Margin="30,510,0,0" 
                VerticalAlignment="Top" Width="820" Height="60">
            <TextBlock x:Name="txtMessage" HorizontalAlignment="Center" VerticalAlignment="Center" 
                      Width="800" FontSize="14" FontWeight="Bold" TextWrapping="Wrap" TextAlignment="Center"/>
        </Border>
    </Grid>
</Window>