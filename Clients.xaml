<Window x:Class="Krasota.Clients"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
        xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
        mc:Ignorable="d"
        Title="Clients" Height="450" Width="800">
    <Grid>
        <Grid.Background>
            <LinearGradientBrush EndPoint="0.5,1" StartPoint="0.5,0">
                <GradientStop Color="White"/>
                <GradientStop Color="Red" Offset="1"/>
                <GradientStop Color="White" Offset="0.335"/>
                <GradientStop Color="#FF0010FF" Offset="0.343"/>
                <GradientStop Color="#FF0010FF" Offset="0.683"/>
                <GradientStop Color="Red" Offset="0.687"/>
            </LinearGradientBrush>
        </Grid.Background>
        <Label x:Name="l_tabC" Content="Клиенты" HorizontalAlignment="Center" Height="37" Margin="0,43,0,0" VerticalAlignment="Top" Width="108" FontSize="20" FontWeight="Bold"/>

        <DataGrid x:Name="clientCell"
                  ItemsSource="{Binding ClientsClass}" ColumnWidth="*"
                  HorizontalAlignment="Left" Height="136" Margin="38,199,0,0" VerticalAlignment="Top" 
                  Width="416" AutoGenerateColumns="False" >
            <DataGrid.Columns>
                <DataGridTextColumn Header="Код" Binding="{Binding ClientCode}" />
                <DataGridTextColumn Header="Имя" Binding="{Binding ClientName}" />
                <DataGridTextColumn Header="Телефон" Binding="{Binding ClientTel, UpdateSourceTrigger=PropertyChanged, Mode=TwoWay}" />
                <DataGridTextColumn Header="Активность" Binding="{Binding ClientActivity}" />
            </DataGrid.Columns>
        </DataGrid>

        <Button x:Name="b_clientDelete" Content="Удалить" HorizontalAlignment="Left" Height="37" Margin="420,123,0,0" VerticalAlignment="Top" Width="136" FontSize="16" FontWeight="Bold" Background="#FFEDEBA1" Click="b_clientDelete_Click"/>
        <Button x:Name="b_clientChange" Content="Изменить" HorizontalAlignment="Left" Height="37" Margin="593,123,0,0" VerticalAlignment="Top" Width="136" FontSize="16" FontWeight="Bold" Background="#FFF1EFA8" Click="b_clientChange_Click"/>
        <Button x:Name="b_clientReturn" Content="Вернуться" HorizontalAlignment="Left" Height="37" Margin="636,360,0,0" VerticalAlignment="Top" Width="136" FontSize="16" FontWeight="Bold" Background="#FFEFEDA9" Click="b_clientReturn_Click"/>
        <Button x:Name="b_clientAdd" Content="Добавить" HorizontalAlignment="Left" Height="37" Margin="38,123,0,0" VerticalAlignment="Top" Width="136" FontSize="16" FontWeight="Bold" Background="#FFEFEDA9" Click="b_clientAdd_Click"/>
        <Button x:Name="b_clientShow" Content="Поиск" HorizontalAlignment="Left" Height="37" Margin="219,123,0,0" VerticalAlignment="Top" Width="136" FontSize="16" FontWeight="Bold" Background="#FFEFEDA9" Click="b_clientShow_Click"/>

        <!-- Новые кнопки -->

    </Grid>
</Window>